PORT=3000

# Ollama — must be running locally with llama3.1:8b pulled
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Supabase — service-role key required (votes table; either disable RLS or use service role)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your-service-role-key

# CORS — comma-separated list of allowed origins. Use chrome-extension://* for the extension.
CORS_ORIGINS=chrome-extension://*,http://localhost:5173
